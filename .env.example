# Copy this file to .env and fill in the values. .env is gitignored.

# --- Required --------------------------------------------------------------
# Your Discord bot token (Developer Portal -> Applications -> Bot -> Reset Token).
FRIENDBOT_TOKEN=

# --- Image backend ---------------------------------------------------------
# Path to your local flux checkout (the one containing generate.py and models/).
# Defaults to ../flux relative to this repo if left unset.
#FLUX_REPO_PATH=/home/you/src/flux

# Which model generate.py loads: sd35 (Stable Diffusion 3.5 Large Turbo) or flux
# (FLUX.1-schnell). Mirrors generate.py's --model option. Default: sd35.
#FRIENDBOT_MODEL=sd35

# --- Optional --------------------------------------------------------------
# Prefix for classic text commands (slash commands always work too).
#FRIENDBOT_PREFIX=!

# Guild id for instant slash-command syncing during development. Leave unset to
# sync commands globally (can take up to an hour to appear).
#FRIENDBOT_GUILD_ID=

# Comma/space separated channel ids the bot will accept prompts in.
# Leave unset to allow every channel.
#FRIENDBOT_CHANNELS=123456789012345678

# Comma/space separated user ids with admin privileges (reserved for future use).
#FRIENDBOT_PRIVILEGED_USERS=219467322421805056

# Queue and fairness knobs.
#FRIENDBOT_MAX_QUEUE=16
#FRIENDBOT_USER_CAP=5

# Delete generated PNGs after upload (true/false).
#FRIENDBOT_DELETE_IMAGES=false

# Snarky cap/slowdown replies (true/false).
#FRIENDBOT_SNARKY=true
